PORT=3000
# AI Provider: gemini | openai | anthropic
AI_PROVIDER=gemini
# AI Models:
# Gemini: gemini-3.1-pro-preview, gemini-3-flash-preview, gemini-2.5-pro, gemini-2.5-flash
# OpenAI: gpt-5.2, gpt-5.2-codex, gpt-5, o4-mini, o3, gpt-4o
# Anthropic: claude-opus-4-20250514, claude-sonnet-4-20250514, claude-3-5-sonnet-20241022
AI_MODEL=gemini-3.1-pro-preview
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# Persona Settings
PERSONA_NAME=Antigravity
HISTORY_LIMIT=30

# WhatsApp Gateway Options (OpenClaw style)
# DM Policy: open | allowlist | disabled
WHATSAPP_DM_POLICY=open
# Comma-separated list of numbers (e.g. 234812345678,234801111111)
WHATSAPP_ALLOW_FROM=
# Group Policy: enabled | disabled
WHATSAPP_GROUP_POLICY=disabled
# Read Receipts: true | false
WHATSAPP_READ_RECEIPTS=true
# Mention Trigger: only reply when message contains this (case-insensitive). Leave empty to reply to all.
WHATSAPP_MENTION_TRIGGER=@Mia
